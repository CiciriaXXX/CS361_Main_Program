# --- Unity 核心忽略文件 ---
# 这些文件夹由 Unity 自动生成，包含大量临时数据和缓存，不应提交

PalettePlugin/[Ll]ibrary/
PalettePlugin/[Tt]emp/
PalettePlugin/[Oo]bj/
PalettePlugin/[Bb]uild/
PalettePlugin/[Bb]uilds/
PalettePlugin/[Ll]ogs/
PalettePlugin/[Mm]emoryCaptures/
PalettePlugin/[Uu]serSettings/

# --- 资源导入缓存 ---
# 只有在确信不需要共享导入设置时才忽略，通常建议忽略以减小仓库体积
PalettePlugin/AssetExplorerCache/

# --- 外部库与插件缓存 ---
PalettePlugin/Assets/AddressableAssetsData/VideoCache/
PalettePlugin/Assets/AddressableAssetsData/ext1/
PalettePlugin/Assets/StreamingAssets/aa/*

# --- IDE (VS/VSCode/Rider) 自动生成的工程文件 ---
# Unity 会根据项目内容自动重新生成这些文件
PalettePlugin/*.csproj
PalettePlugin/*.unityproj
PalettePlugin/*.sln
PalettePlugin/*.suo
PalettePlugin/*.tmp
PalettePlugin/*.user
PalettePlugin/*.userprefs
PalettePlugin/*.pidb
PalettePlugin/*.booproj
PalettePlugin/*.svd
PalettePlugin/*.pdb
PalettePlugin/*.mdb
PalettePlugin/*.opendb
PalettePlugin/*.db

# --- 文件夹与元数据 ---
PalettePlugin/.vs/
PalettePlugin/.idea/
PalettePlugin/.gradle/
PalettePlugin/.vsconfig

# --- 操作系统临时文件 ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
Thumbs.db

# --- 其他 ---
# 如果你有导出的包或压缩包，通常也不建议提交
*.unitypackage
*.zip
*.7z